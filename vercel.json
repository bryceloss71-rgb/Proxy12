{
  "version": 2,
  "rewrites": [
    {
      "source": "/uv/(.*)",
      "destination": "/api/index.js"
    }
  ],
  "headers": [
    {
      "source": "/uv/uv.sw.js",
      "headers": [
        { "key": "Service-Worker-Allowed", "value": "/" },
        { "key": "Content-Type", "value": "application/javascript" }
      ]
    }
  ]
}